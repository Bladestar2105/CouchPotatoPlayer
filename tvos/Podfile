# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  patch_pods_for_tvos(installer)

  installer.pods_project.build_configurations.each do |config|
    config.build_settings["ENABLE_USER_SCRIPT_SANDBOXING"] = "NO"
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # set framework search path
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] = "\"#{File.expand_path("..", $PROJECT_DIR)}/ios/Flutter\" $(inherited)"
      config.build_settings["ONLY_ACTIVE_ARCH"] = "YES"
      config.build_settings["TVOS_DEPLOYMENT_TARGET"] = "15.0"
      # convert ios to tvos target
      if config.build_settings["TARGETED_DEVICE_FAMILY"]
        config.build_settings["TARGETED_DEVICE_FAMILY"] = "3"
      end
      if config.build_settings["SDKROOT"]
        config.build_settings["SDKROOT"] = "appletvos"
      end
      if config.build_settings["SUPPORTED_PLATFORMS"]
        config.build_settings["SUPPORTED_PLATFORMS"] = "appletvos"
      end
      if config.build_settings["ENABLE_BITCODE"]
        config.build_settings["ENABLE_BITCODE"] = "NO"
      end
      config.build_settings["ENABLE_USER_SCRIPT_SANDBOXING"] = "NO"
    end
  end
end

def patch_pods_for_tvos(installer)
  pods_dir = installer.pods_project.path.dirname
  symlinks_dir = File.expand_path(File.join(pods_dir, '..', '.symlinks', 'plugins'))

  # Resolve symlinks so Dir.glob works properly
  real_symlink_paths = []
  if Dir.exist?(symlinks_dir)
    Dir.foreach(symlinks_dir) do |plugin|
      next if plugin == '.' or plugin == '..'
      plugin_path = File.join(symlinks_dir, plugin)
      if File.symlink?(plugin_path) || File.exist?(plugin_path)
        real_symlink_paths << File.realpath(plugin_path)
      end
    end
  end

  # Helper to get all swift files
  def get_all_swift_files(pods_dir, real_symlink_paths, file_pattern)
    files = Dir.glob(File.join(pods_dir, "**/#{file_pattern}"))
    real_symlink_paths.each do |real_path|
      files += Dir.glob(File.join(real_path, "**/#{file_pattern}"))
    end
    files
  end

  # Patch all Swift files to handle Flutter import for tvOS
  get_all_swift_files(pods_dir, real_symlink_paths, '*.swift').each do |file|
    next if file.include?('Pods/')  # Skip generated Pods files
    
    content = File.read(file)
    patched_content = content
    
    # Check if this file has Flutter import issues
    has_flutter_import = content.include?('import Flutter')
    has_tvos_condition = content.include?('os(tvOS)') || content.include?('tvOS')
    has_ios_condition = content.include?('os(iOS)')
    
    # Case 1: #if os(iOS) || os(tvOS) import Flutter
    if content.include?('#if os(iOS)') && content.include?('import Flutter')
      if patched_content.include?("#if os(iOS)\n  import Flutter\n#elseif os(macOS)")
        patched_content = patched_content.gsub("#if os(iOS)\n  import Flutter", "#if os(iOS) || os(tvOS)\n  import Flutter")
      elsif patched_content.include?("#if os(iOS)\nimport Flutter\n#elseif os(macOS)")
        patched_content = patched_content.gsub("#if os(iOS)\nimport Flutter", "#if os(iOS) || os(tvOS)\nimport Flutter")
      elsif patched_content.include?("#if os(iOS)\n  import Flutter\n#endif")
        patched_content = patched_content.gsub("#if os(iOS)\n  import Flutter", "#if os(iOS) || os(tvOS)\n  import Flutter")
      elsif patched_content.include?("#if os(iOS)\nimport Flutter\n#endif")
        patched_content = patched_content.gsub("#if os(iOS)\nimport Flutter", "#if os(iOS) || os(tvOS)\nimport Flutter")
    end
    
    # Case 2: Plain "import Flutter" without any conditions
    if has_flutter_import && !has_tvos_condition && !has_ios_condition
      # Add tvOS-specific UIKit import after Flutter
      patched_content = patched_content.gsub("import Flutter", "import Flutter\n#if os(tvOS)\nimport UIKit\n#endif")
    end
    
    # Fix binaryMessenger calls
    if patched_content.include?("binaryMessenger: messenger") && !patched_content.include?("binaryMessenger: messenger()")
      patched_content = patched_content.gsub("binaryMessenger: messenger", "binaryMessenger: messenger()")
    end
    
    if patched_content != content
      puts "Patching Swift file for tvOS: #{file}"
      File.write(file, patched_content)
    end
  end

  # Patch URLLaunchSession.swift - wrap entire file in iOS guard
  get_all_swift_files(pods_dir, real_symlink_paths, 'URLLaunchSession.swift').each do |file|
    content = File.read(file)
    if !content.start_with?("#if os(iOS)")
      puts "Patching URLLaunchSession.swift: #{file}"
      File.write(file, "#if os(iOS)\n" + content + "\n#endif\n")
    end
  end

  # Patch URLLauncherPlugin.swift
  get_all_swift_files(pods_dir, real_symlink_paths, 'URLLauncherPlugin.swift').each do |file|
    content = File.read(file)
    patched_content = content

    # Guard currentSession variable
    if patched_content.include?("private var currentSession: URLLaunchSession?") && !patched_content.include?("#if os(iOS)\n  private var currentSession: URLLaunchSession?\n#endif")
      patched_content = patched_content.gsub("private var currentSession: URLLaunchSession?", "#if os(iOS)\n  private var currentSession: URLLaunchSession?\n#endif")
    end

    # Guard SafariViewController methods
    if patched_content.include?("func openUrlInSafariViewController") && !patched_content.include?("#if os(iOS)\n  func openUrlInSafariViewController")
      pattern = /func openUrlInSafariViewController[\s\S]*?func closeSafariViewController\(\) \{[\s\S]*?\n  \}/
      replacement = "#if os(iOS)\n  \\0\n#else\n  func openUrlInSafariViewController(\n    url: String,\n    completion: @escaping (Result<InAppLoadResult, Error>) -> Void\n  ) {\n    completion(.success(.failedToLoad))\n  }\n  func closeSafariViewController() {}\n#endif"
      patched_content = patched_content.gsub(pattern, replacement)
    end

    if patched_content != content
      puts "Patching URLLauncherPlugin.swift: #{file}"
      File.write(file, patched_content)
    end
  end

  # Patch VideoOutput.swift for media_kit_video
  get_all_swift_files(pods_dir, real_symlink_paths, 'VideoOutput.swift').each do |file|
    content = File.read(file)
    if content.include?("import Flutter") && !content.include?("os(tvOS)")
      patched_content = content.gsub("import Flutter", "import Flutter\n#if os(tvOS)\nimport UIKit\n#endif")
      if patched_content != content
        puts "Patching VideoOutput.swift: #{file}"
        File.write(file, patched_content)
      end
    end
  end
end
