# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  patch_pods_for_tvos(installer)

  installer.pods_project.build_configurations.each do |config|
    config.build_settings["ENABLE_USER_SCRIPT_SANDBOXING"] = "NO"
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # set framework search path
      flutter_dir = File.expand_path('..', $PROJECT_DIR) + '/ios/Flutter'
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] = '"' + flutter_dir + '" $(inherited)'
      config.build_settings['HEADER_SEARCH_PATHS'] = '"' + flutter_dir + '" $(inherited)'
      config.build_settings["ONLY_ACTIVE_ARCH"] = "YES"
      config.build_settings["TVOS_DEPLOYMENT_TARGET"] = "15.0"
      # convert ios to tvos target
      if config.build_settings["TARGETED_DEVICE_FAMILY"]
        config.build_settings["TARGETED_DEVICE_FAMILY"] = "3"
      end
      if config.build_settings["SDKROOT"]
        config.build_settings["SDKROOT"] = "appletvos"
      end
      if config.build_settings["SUPPORTED_PLATFORMS"]
        config.build_settings["SUPPORTED_PLATFORMS"] = "appletvos"
      end
      if config.build_settings["ENABLE_BITCODE"]
        config.build_settings["ENABLE_BITCODE"] = "NO"
      end
      config.build_settings["ENABLE_USER_SCRIPT_SANDBOXING"] = "NO"
    end
  end
end

def patch_pods_for_tvos(installer)
  pods_dir = installer.pods_project.path.dirname

  # Collect all directories to search for Swift files.
  # IMPORTANT: CocoaPods with Swift Package Manager style sources compiles files
  # directly from ~/.pub-cache, so we must patch those files too.
  search_dirs = [pods_dir.to_s]

  # Resolve .symlinks/plugins symlinks
  symlinks_dir = File.expand_path(File.join(pods_dir, '..', '.symlinks', 'plugins'))
  if Dir.exist?(symlinks_dir)
    Dir.foreach(symlinks_dir) do |plugin|
      next if plugin == '.' || plugin == '..'
      plugin_path = File.join(symlinks_dir, plugin)
      begin
        real_path = File.realpath(plugin_path)
        search_dirs << real_path
      rescue
      end
    end
  end

  # Add pub cache directory - this is where SPM-style pods compile from
  pub_cache_dir = File.expand_path('~/.pub-cache/hosted/pub.dev')
  search_dirs << pub_cache_dir if Dir.exist?(pub_cache_dir)

  # Helper: collect unique Swift files matching a glob pattern
  def collect_swift_files(search_dirs, pattern)
    files = []
    search_dirs.each do |dir|
      files += Dir.glob(File.join(dir, "**", pattern))
    end
    files.uniq
  end

  # ---------------------------------------------------------------------------
  # PATCH 1: Fix Pigeon-generated files and any Swift file with
  #   "#if os(iOS)\n  import Flutter\n#elseif os(macOS)\n...\n#else\n  #error(...)\n#endif"
  # tvOS falls into the #error branch → replace with || os(tvOS) and remove #error
  # ---------------------------------------------------------------------------
  collect_swift_files(search_dirs, '*.swift').each do |file|
    content = File.read(file)
    patched = content

    # Use robust regex instead of exact string replacement for Flutter imports

    # Replace "#if os(iOS)" with "#if os(iOS) || os(tvOS)" where "import Flutter" is present
    patched = patched.gsub(/(#if\s+os\(iOS\))(\n\s*import\s+Flutter\b)/, '\1 || os(tvOS)\2')

    # Remove #else \n #error("Unsupported platform.") block if we just patched an iOS/macOS branch
    if patched.include?("os(tvOS)") && patched.include?("#error(\"Unsupported platform.\")")
      patched = patched.gsub(/\n\s*#else\n\s*#error\("Unsupported platform\."\)\n(#endif)/, "\n\\1")
    end

    # Pattern F: bare "import Flutter" with no platform guard
    if patched.include?("import Flutter") &&
       !patched.include?("os(tvOS)") &&
       !patched.include?("os(iOS)") &&
       !patched.include?("canImport(Flutter)")
      patched = patched.gsub("import Flutter", "#if os(iOS) || os(tvOS)\nimport Flutter\n#endif")
    end

    if patched != content
      puts "Patching (Flutter import) #{file}"
      File.write(file, patched)
    end
  end

  # ---------------------------------------------------------------------------
  # PATCH 2: URLLaunchSession.swift
  # Uses SafariServices (SFSafariViewController) which is iOS-only.
  # Wrap the entire file in #if os(iOS) ... #endif
  # ---------------------------------------------------------------------------
  collect_swift_files(search_dirs, 'URLLaunchSession.swift').each do |file|
    content = File.read(file)
    unless content.start_with?("#if os(iOS)")
      puts "Patching URLLaunchSession.swift: #{file}"
      File.write(file, "#if os(iOS)\n" + content + "\n#endif\n")
    end
  end

  # ---------------------------------------------------------------------------
  # PATCH 3: Launcher.swift (url_launcher_ios)
  # Uses UIApplication.shared.open with OpenExternalURLOptionsKey (different on tvOS).
  # Wrap entire file in #if os(iOS) ... #endif
  # ---------------------------------------------------------------------------
  collect_swift_files(search_dirs, 'Launcher.swift').each do |file|
    content = File.read(file)
    # Only patch if it's the url_launcher Launcher (contains UIApplication.shared)
    if content.include?("UIApplication.shared") && !content.start_with?("#if os(iOS)")
      puts "Patching Launcher.swift: #{file}"
      File.write(file, "#if os(iOS)\n" + content + "\n#endif\n")
    end
  end

  # ---------------------------------------------------------------------------
  # PATCH 4: ViewPresenter.swift (url_launcher_ios 6.4.1+)
  # Uses UIViewController and registrar.viewController (iOS-only).
  # Wrap entire file in #if os(iOS) ... #endif
  # ---------------------------------------------------------------------------
  collect_swift_files(search_dirs, 'ViewPresenter.swift').each do |file|
    content = File.read(file)
    if content.include?("UIViewController") && !content.start_with?("#if os(iOS)")
      puts "Patching ViewPresenter.swift: #{file}"
      File.write(file, "#if os(iOS)\n" + content + "\n#endif\n")
    end
  end

  # ---------------------------------------------------------------------------
  # PATCH 5: URLLauncherPlugin.swift
  # References URLLaunchSession, ViewPresenterProvider (iOS-only types).
  # Replace with a tvOS-compatible stub for the iOS-only parts.
  # ---------------------------------------------------------------------------
  collect_swift_files(search_dirs, 'URLLauncherPlugin.swift').each do |file|
    content = File.read(file)
    next if content.include?("os(tvOS)")

    patched = content

    # Replace imports at top: "import Flutter\nimport UIKit" with platform-guarded version
    patched = patched.gsub(
      "import Flutter\nimport UIKit",
      "#if os(iOS)\nimport Flutter\nimport UIKit\n#elseif os(tvOS)\nimport Flutter\nimport UIKit\n#endif"
    )

    # Wrap currentSession property (depends on URLLaunchSession which is iOS-only)
    if patched.include?("private var currentSession: URLLaunchSession?")
      patched = patched.gsub(
        "  private var currentSession: URLLaunchSession?",
        "#if os(iOS)\n  private var currentSession: URLLaunchSession?\n#endif"
      )
    end

    # Wrap viewPresenterProvider property (depends on ViewPresenterProvider iOS-only)
    if patched.include?("private let viewPresenterProvider: ViewPresenterProvider")
      patched = patched.gsub(
        "  private let viewPresenterProvider: ViewPresenterProvider",
        "#if os(iOS)\n  private let viewPresenterProvider: ViewPresenterProvider\n#endif"
      )
    end

    # Wrap the init that takes viewPresenterProvider
    if patched.include?("init(launcher: Launcher = DefaultLauncher(), viewPresenterProvider: ViewPresenterProvider)")
      patched = patched.gsub(
        "  init(launcher: Launcher = DefaultLauncher(), viewPresenterProvider: ViewPresenterProvider) {\n    self.launcher = launcher\n    self.viewPresenterProvider = viewPresenterProvider\n  }",
        "#if os(iOS)\n  init(launcher: Launcher = DefaultLauncher(), viewPresenterProvider: ViewPresenterProvider) {\n    self.launcher = launcher\n    self.viewPresenterProvider = viewPresenterProvider\n  }\n#else\n  init(launcher: Launcher = DefaultLauncher()) {\n    self.launcher = launcher\n  }\n#endif"
      )
    end

    # For older 6.3.x that has init without viewPresenterProvider
    if patched.include?("init(launcher: Launcher = DefaultLauncher()) {") && !patched.include?("viewPresenterProvider")
      # nothing needed
    end

    # Wrap register func that uses DefaultViewPresenterProvider (iOS-only)
    if patched.include?("DefaultViewPresenterProvider(registrar: registrar)")
      patched = patched.gsub(
        "  public static func register(with registrar: FlutterPluginRegistrar) {\n    let plugin = URLLauncherPlugin(\n      viewPresenterProvider: DefaultViewPresenterProvider(registrar: registrar))\n    UrlLauncherApiSetup.setUp(binaryMessenger: registrar.messenger(), api: plugin)\n    registrar.publish(plugin)\n  }",
        "  public static func register(with registrar: FlutterPluginRegistrar) {\n#if os(iOS)\n    let plugin = URLLauncherPlugin(\n      viewPresenterProvider: DefaultViewPresenterProvider(registrar: registrar))\n#else\n    let plugin = URLLauncherPlugin()\n#endif\n    UrlLauncherApiSetup.setUp(binaryMessenger: registrar.messenger(), api: plugin)\n    registrar.publish(plugin)\n  }"
      )
    end

    # Wrap openUrlInSafariViewController and closeSafariViewController methods
    if patched.include?("func openUrlInSafariViewController") &&
       !patched.include?("#if os(iOS)\n  func openUrlInSafariViewController")
      patched = patched.gsub(
        /( +func openUrlInSafariViewController[\s\S]*?func closeSafariViewController\(\) \{[\s\S]*?\n  \})/
      ) do |match|
        "#if os(iOS)\n#{match}\n#else\n  func openUrlInSafariViewController(\n    url: String,\n    completion: @escaping (Result<InAppLoadResult, Error>) -> Void\n  ) {\n    completion(.success(.failedToLoad))\n  }\n  func closeSafariViewController() {}\n#endif"
      end
    end

    if patched != content
      puts "Patching URLLauncherPlugin.swift: #{file}"
      File.write(file, patched)
    end
  end

  # ---------------------------------------------------------------------------
  # PATCH 6: media_kit_video VideoOutput.swift and related files
  # Uses #if canImport(Flutter) which should work, but may need UIKit on tvOS
  # ---------------------------------------------------------------------------
  collect_swift_files(search_dirs, 'VideoOutput.swift').each do |file|
    content = File.read(file)
    patched = content

    if patched.include?("#if canImport(Flutter)\n  import Flutter") && !patched.include?("os(tvOS)")
      patched = patched.gsub(
        "#if canImport(Flutter)\n  import Flutter\n#elseif canImport(FlutterMacOS)\n  import FlutterMacOS\n#endif",
        "#if canImport(Flutter)\n  import Flutter\n#elseif canImport(FlutterMacOS)\n  import FlutterMacOS\n#endif\n#if os(tvOS)\nimport UIKit\n#endif"
      )
    end

    if patched != content
      puts "Patching VideoOutput.swift: #{file}"
      File.write(file, patched)
    end
  end

  # ---------------------------------------------------------------------------
  # PATCH 7: Patch Package.swift files to add tvOS platform support
  # All iOS-only SPM packages fail ScanDependencies when built for tvOS
  # because they don't declare tvOS in their platforms array.
  # ---------------------------------------------------------------------------
  def collect_package_swift_files(search_dirs)
    files = []
    search_dirs.each do |dir|
      files += Dir.glob(File.join(dir, "**/Package.swift"))
    end
    files.select { |f| f.include?("/ios/") }.uniq
  end

  collect_package_swift_files(search_dirs).each do |file|
    content = File.read(file)
    next if content.include?("tvOS")
    patched = content

    # Add .tvOS("15.0") to the platforms array, handling various indent/comma styles:
    # Style A: .iOS("x.x")\n    ]          (no trailing comma)
    # Style B: .iOS("x.x"),\n    ]         (trailing comma before closing bracket)
    if patched.include?(".iOS(") && !patched.include?(".tvOS(")
      # Style A: no trailing comma - add comma + tvOS before ]
      patched = patched.gsub(/(\s+\.iOS\("[^"]+"\))(,?\s*\n(\s*)\])/) do |_match|
        ios_line = $1
        rest = $2
        indent = $3
        ios_line + ",\n" + indent + ".tvOS(&quot;15.0&quot;)" + rest
      end
    end

    if patched != content
      puts "Patching Package.swift for tvOS: #{file}"
      File.write(file, patched)
    end
  end

  # ---------------------------------------------------------------------------
  # PATCH 8: wakelock_plus Objective-C files
  # WakelockPlusPlugin.h/m uses #import <Flutter/Flutter.h> (needs tvOS guard)
  # WakelockPlusPlugin.m uses isIdleTimerDisabled which is iOS-only on tvOS
  # UIApplication+idleTimerLock uses method swizzling (iOS-only)
  # messages.g.m uses #import <Flutter/Flutter.h> without tvOS guard
  # ---------------------------------------------------------------------------

  # Helper: collect ObjC files
  def collect_objc_files(search_dirs, pattern)
    files = []
    search_dirs.each do |dir|
      files += Dir.glob(File.join(dir, "**", pattern))
    end
    files.uniq
  end

  # Patch WakelockPlusPlugin.h - replace bare Flutter import with guarded one
  collect_objc_files(search_dirs, 'WakelockPlusPlugin.h').each do |file|
    content = File.read(file)
    patched = content
    if patched.include?("#import <Flutter/Flutter.h>") && !patched.include?("TARGET_OS_TV")
      patched = patched.gsub(
        "#import <Flutter/Flutter.h>",
        "#if TARGET_OS_TV\n#import <Flutter/Flutter.h>\n#else\n#import <Flutter/Flutter.h>\n#endif"
      )
      # Actually just keep it - Flutter framework is available on tvOS too via custom engine
      # The real fix is messages.g.m and WakelockPlusPlugin.m
    end
  end

  # Patch messages.g.m - fix Flutter import for tvOS
  collect_objc_files(search_dirs, 'messages.g.m').each do |file|
    next unless file.include?("wakelock_plus")
    content = File.read(file)
    patched = content
    # Replace the macOS/iOS guard with one that also covers tvOS
    if patched.include?("#if TARGET_OS_OSX\n#import <FlutterMacOS/FlutterMacOS.h>\n#else\n#import <Flutter/Flutter.h>\n#endif") && !patched.include?("TARGET_OS_TV")
      patched = patched.gsub(
        "#if TARGET_OS_OSX\n#import <FlutterMacOS/FlutterMacOS.h>\n#else\n#import <Flutter/Flutter.h>\n#endif",
        "#if TARGET_OS_OSX\n#import <FlutterMacOS/FlutterMacOS.h>\n#else\n#import <Flutter/Flutter.h>\n#endif"
      )
      # This is actually fine - #else covers both iOS and tvOS
    end
    if patched != content
      puts "Patching wakelock_plus messages.g.m: #{file}"
      File.write(file, patched)
    end
  end

  # Patch WakelockPlusPlugin.m - wrap iOS-only APIs in TARGET_OS_IOS guard
  collect_objc_files(search_dirs, 'WakelockPlusPlugin.m').each do |file|
    content = File.read(file)
    next if content.include?("TARGET_OS_TV")
    patched = content

    # Wrap the entire implementation in TARGET_OS_IOS guard and provide tvOS stub
    if patched.include?("@implementation WakelockPlusPlugin") && !patched.include?("TARGET_OS_TV")
      tvos_stub = <<~OBJC

        #if TARGET_OS_TV
        // tvOS stub - wakelock is not supported on tvOS
        @implementation WakelockPlusPlugin
        + (void)registerWithRegistrar:(NSObject<FlutterPluginRegistrar>*)registrar {
          WakelockPlusPlugin* instance = [[WakelockPlusPlugin alloc] init];
          SetUpWAKELOCKPLUSWakelockPlusApi(registrar.messenger, instance);
        }
        - (void)toggleMsg:(WAKELOCKPLUSToggleMessage*)input error:(FlutterError**)error {
          // No-op on tvOS
        }
        - (WAKELOCKPLUSIsEnabledMessage*)isEnabledWithError:(FlutterError* __autoreleasing *)error {
          WAKELOCKPLUSIsEnabledMessage* result = [[WAKELOCKPLUSIsEnabledMessage alloc] init];
          result.enabled = @NO;
          return result;
        }
        @end
        #else
      OBJC

      # Find the start of @implementation WakelockPlusPlugin
      impl_start = patched.index("@implementation WakelockPlusPlugin")
      # Find the matching @end
      end_pos = patched.index("\n@end", impl_start)
      if end_pos
        end_pos_after = end_pos + "\n@end".length
        original_impl = patched[impl_start..end_pos_after-1]
        patched = patched.sub(original_impl, tvos_stub + original_impl + "\n#endif")
      end
    end

    if patched != content
      puts "Patching WakelockPlusPlugin.m: #{file}"
      File.write(file, patched)
    end
  end

  # Patch UIApplication+idleTimerLock.m - wrap in TARGET_OS_IOS guard
  collect_objc_files(search_dirs, 'UIApplication+idleTimerLock.m').each do |file|
    content = File.read(file)
    unless content.start_with?("#if TARGET_OS_IOS") || content.include?("TARGET_OS_TV")
      puts "Patching UIApplication+idleTimerLock.m: #{file}"
      File.write(file, "#if !TARGET_OS_TV\n" + content + "\n#endif\n")
    end
  end

  # Patch UIApplication+idleTimerLock.h - wrap in TARGET_OS_IOS guard
  collect_objc_files(search_dirs, 'UIApplication+idleTimerLock.h').each do |file|
    content = File.read(file)
    unless content.include?("TARGET_OS_TV")
      puts "Patching UIApplication+idleTimerLock.h: #{file}"
      File.write(file, "#if !TARGET_OS_TV\n" + content + "\n#endif\n")
    end
  end
end